<?xml version="1.0" encoding="UTF-8"?>
<PARAMDEF XmlVersion="0">
    <ParamType>ITEM_USAGE_PARAM</ParamType>
    <DataVersion>8</DataVersion>
    <BigEndian>true</BigEndian>
    <Unicode>true</Unicode>
    <FormatVersion>105</FormatVersion>
    <Fields>
        <Field Def="s32 eventFlag = -1">
            <DisplayName>使用許可するイベントフラグ</DisplayName>
            <Description>使用許可するイベントフラグ。-1ならば無視</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Minimum>-1</Minimum>
            <Maximum>1e+09</Maximum>
            <Increment>1</Increment>
            <SortID>1</SortID>
        </Field>
        <Field Def="u8 condition">
            <DisplayName>指定状態のみ許可</DisplayName>
            <Enum>ITEM_USE_PERMIT_TYPE_CONDITION</Enum>
            <Description>指定状態のみ許可</Description>
            <SortID>100</SortID>
        </Field>
        <Field Def="u8 isAllowUseOnLadder:1">
            <DisplayName>はしご中使用許可</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>はしご中使用許可</Description>
            <SortID>1</SortID>
        </Field>
        <Field Def="u8 isAllowMultipleUse:1">
            <DisplayName>使用個数設定許可</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>使用個数設定許可</Description>
            <SortID>1</SortID>
        </Field>
        <Field Def="u8 isConsume:1">
            <DisplayName>消耗品</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>消耗品</Description>
            <SortID>1</SortID>
        </Field>
        <Field Def="u8 isNormalConsumu:1">
            <DisplayName>通常タイミングで消費する</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>通常タイミングで消費する</Description>
            <SortID>1</SortID>
        </Field>
        <Field Def="u8 permitOnlineSingle:1">
            <DisplayName>オンラインシングルプレイ許可</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>オンラインかつ、（協力に限らず）霊体を召喚していない状態</Description>
            <SortID>110</SortID>
        </Field>
        <Field Def="u8 permitOnlineMulti:1">
            <DisplayName>マルチプレイ許可</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>オン・オフ関係なく、（協力霊に限らず）霊体を召喚している状態</Description>
            <SortID>110</SortID>
        </Field>
        <Field Def="u8 permitOffline:1">
            <DisplayName>オフライン許可</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>オフラインの状態</Description>
            <SortID>110</SortID>
        </Field>
        <Field Def="u8 permitOnlineGuest:1">
            <DisplayName>ゲスト時許可</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>自分自身がホストではない場合</Description>
            <SortID>110</SortID>
        </Field>
        <Field Def="u8 permitBattlePhantom:1">
            <DisplayName>決闘霊体時許可</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>決闘青霊、決闘赤霊の状態</Description>
            <SortID>110</SortID>
        </Field>
        <Field Def="u8 permitLeave:1">
            <DisplayName>破棄許可</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>破棄許可</Description>
            <SortID>110</SortID>
        </Field>
        <Field Def="u8 permitDrop:1">
            <DisplayName>譲渡許可</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>譲渡許可</Description>
            <SortID>110</SortID>
        </Field>
        <Field Def="u8 exEvalFuncID">
            <DisplayName>拡張使用許可判定関数ID（仮）</DisplayName>
            <Description>フラグの設定では解決できない複雑な判定を使用する場合の関数ID。IDはプログラム内部の処理と対応している。生者・亡者判定以降を、フラグ判定と切り替える。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>255</Maximum>
            <Increment>1</Increment>
            <SortID>120</SortID>
        </Field>
    </Fields>
</PARAMDEF>
