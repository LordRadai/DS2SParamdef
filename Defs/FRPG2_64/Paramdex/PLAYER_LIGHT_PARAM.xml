        <Field Def="u16 diffuseA">
            <DisplayName>デフューズA</DisplayName>
            <Description>デフューズのαを設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>4095</Maximum>
            <Increment>1</Increment>
            <SortID>6</SortID>
        </Field>
        <Field Def="u16 specularA">
            <DisplayName>スペキュラA</DisplayName>
            <Description>スペキュラのαを設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>4095</Maximum>
            <Increment>1</Increment>
            <SortID>10</SortID>
        </Field>
        <Field Def="f32 radius">
            <DisplayName>ライトの半径</DisplayName>
            <Description>ライトの半径を設定します。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Maximum>999</Maximum>
            <Increment>1</Increment>
            <SortID>11</SortID>
        </Field>
        <Field Def="f32 priority">
            <DisplayName>優先度</DisplayName>
            <Description>表示しようとする光源の優先度(0.0～1.0)です。表示できる光源の最大数を超えた場合には優先度が高いものほど表示されやすくなります。ただし、状況に応じて順序が前後する可能性もあります。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.1</Increment>
            <SortID>12</SortID>
        </Field>
        <Field Def="f32 depthShadow">
            <DisplayName>影の濃さ</DisplayName>
            <Description>影の濃さ(0.0～1.0)です。高いほど濃く表示され、0.0で影無効と同等の処理となります。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.1</Increment>
            <SortID>14</SortID>
        </Field>
        <Field Def="u16 blinkTimeMax">
            <DisplayName>明滅の時間(最大)</DisplayName>
            <Description>明滅の最小時間を設定します。最小～最大の範囲からランダムで抽出された値が1回の明滅時間となり、明滅毎に繰り返します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>99</Maximum>
            <Increment>1</Increment>
            <SortID>15</SortID>
        </Field>
        <Field Def="u16 blinkTimeMin">
            <DisplayName>明滅の時間(最小)</DisplayName>
            <Description>明滅の最大時間を設定します。最小～最大の範囲からランダムで抽出された値が1回の明滅時間となり、明滅毎に繰り返します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>99</Maximum>
            <Increment>1</Increment>
            <SortID>16</SortID>
        </Field>
        <Field Def="f32 blinkPower">
            <DisplayName>明滅の強さ</DisplayName>
            <Description>明滅の最小強さを設定します。最小～1.0の範囲での強さで明滅が行われます。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.1</Increment>
            <SortID>17</SortID>
        </Field>
        <Field Def="f32 windDepthShadow">
            <DisplayName>影響後の影の濃さ</DisplayName>
            <Description>風の影響を受けた後の影の濃さ(0.0～1.0)です。高いほど濃く表示され、0.0で影無効と同等の処理となります。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.1</Increment>
            <SortID>19</SortID>
        </Field>
        <Field Def="u16 windBlinkTimeMax">
            <DisplayName>影響後の明滅の時間(最大)</DisplayName>
            <Description>風の影響を受けた後の明滅の最小時間を設定します。最小～最大の範囲からランダムで抽出された値が1回の明滅時間となり、明滅毎に繰り返します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>99</Maximum>
            <Increment>1</Increment>
            <SortID>20</SortID>
        </Field>
        <Field Def="u16 windBlinkTimeMin">
            <DisplayName>影響後の明滅の時間(最小)</DisplayName>
            <Description>風の影響を受けた後の明滅の最大時間を設定します。最小～最大の範囲からランダムで抽出された値が1回の明滅時間となり、明滅毎に繰り返します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>99</Maximum>
            <Increment>1</Increment>
            <SortID>21</SortID>
        </Field>
        <Field Def="f32 windBlinkPower">
            <DisplayName>影響後の明滅の強さ</DisplayName>
            <Description>風の影響を受けた後の明滅の最小強さを設定します。最小～1.0の範囲での強さで明滅が行われます。</Description>
            <DisplayFormat>%.1f</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>0.1</Increment>
            <SortID>22</SortID>
        </Field>
        <Field Def="u8 enableShadow">
            <DisplayName>影を落とす</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>影を落とすかを設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>1</Increment>
            <SortID>13</SortID>
        </Field>
        <Field Def="u8 enableWind">
            <DisplayName>風の影響を受ける</DisplayName>
            <Enum>BOOL_CIRCLECROSS_TYPE</Enum>
            <Description>風の影響を受けるかを設定します。</Description>
            <DisplayFormat>%d</DisplayFormat>
            <Maximum>1</Maximum>
            <Increment>1</Increment>
            <SortID>18</SortID>
        </Field>
